# --------------------------------------------------------------------------
# Security hardening for School Management System
# --------------------------------------------------------------------------

# --------------------------------------------------------------------------
# Folder-name independence
# --------------------------------------------------------------------------
# The app's internal links are absolute and begin with /school_ms/. When the
# app is deployed under a DIFFERENT folder name (or directly at the domain
# root), there is no physical "school_ms" folder, so those links would 404.
# This rule strips the /school_ms/ prefix ONLY when the requested path does not
# exist as a real file/folder here -- which is exactly the situation on such a
# host. Locally, where the app really lives in a school_ms/ folder, the files
# DO exist, so the rule never fires and behaviour is unchanged.
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^school_ms/(.*)$ $1 [L,QSA]
</IfModule>

# Block direct web access to developer / setup / migration / debug scripts.
# These are maintenance tools and must not be reachable over HTTP in production.
# (Patterns are chosen to avoid matching legitimate app files such as
#  create.php or add_item.php.)
<FilesMatch "^(test[-_].*|.*[-_]test|debug[-_].*|fix_.*|setup_.*|migrate_.*|seed_.*|db_test|quick_setup|run_database_fixes|update_database|update_academic_records|update_user_roles|check_database|check_table_structure|create_academic_tables|create_parent_students_table|create_simple_class|create_test_parent|add_col|add_profile_column|add_sample_data|add_sidebar_transitions)\.php$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Never serve raw SQL dumps or backups if they end up under the web root.
<FilesMatch "\.(sql|sql\.gz|bak|log|md|sh)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Baseline security response headers (safe, no impact on app behaviour).
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set X-XSS-Protection "1; mode=block"
</IfModule>

# Disable directory listings.
Options -Indexes
